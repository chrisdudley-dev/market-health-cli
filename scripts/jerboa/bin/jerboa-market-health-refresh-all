#!/usr/bin/env bash
set -Eeuo pipefail

# Parse flags (only --force is special here)
FORCE=0
ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1; shift ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

# Paths
ENV_JSON="${HOME}/.cache/jerboa/environment.v1.json"
SECT_JSON="${HOME}/.cache/jerboa/market_health.sectors.json"
POS_JSON="${HOME}/.cache/jerboa/positions.v1.json"

# Lock to prevent overlaps
LOCKDIR="${HOME}/.cache/jerboa/locks"
LOCK="${LOCKDIR}/market_health_refresh_all.lock"
mkdir -p "$LOCKDIR"
exec 9>"$LOCK"
if ! flock -n 9; then
  exit 0
fi

# Helper: stat mtime or 0
mtime() { stat -c %Y "$1" 2>/dev/null || echo 0; }

b_env="$(mtime "$ENV_JSON")"
b_sect="$(mtime "$SECT_JSON")"
b_pos="$(mtime "$POS_JSON")"

# Positions refresh:
# If user provided an explicit --csv <path>, pass it through; otherwise run auto-pick mode.
if [ "${ARGS[0]:-}" = "--csv" ] && [ -n "${ARGS[1]:-}" ]; then
  "${HOME}/bin/jerboa-market-health-positions-refresh" --csv "${ARGS[1]}"
else
  "${HOME}/bin/jerboa-market-health-positions-refresh"
fi

# Market refresh:
# IMPORTANT: do NOT use ${ARGS[@]:-} (can inject an empty arg). Use "${ARGS[@]}" only.
if [ "$FORCE" -eq 1 ]; then
  "${HOME}/bin/jerboa-market-health-refresh" --force "${ARGS[@]}"
else
  "${HOME}/bin/jerboa-market-health-refresh" "${ARGS[@]}"
fi

a_env="$(mtime "$ENV_JSON")"
a_sect="$(mtime "$SECT_JSON")"
a_pos="$(mtime "$POS_JSON")"

changed_market=0
changed_pos=0
[ "$a_env"  -gt "$b_env"  ] && changed_market=1
[ "$a_sect" -gt "$b_sect" ] && changed_market=1
[ "$a_pos"  -gt "$b_pos"  ] && changed_pos=1

# Under systemd: emit ONE breadcrumb only if something changed
if [ -n "${INVOCATION_ID:-}" ]; then
  if [ "$changed_market" -eq 1 ] || [ "$changed_pos" -eq 1 ]; then
    echo "OK: refresh-all updated (market=${changed_market} positions=${changed_pos})"
  fi
else
  echo "refresh-all: market_changed=${changed_market} positions_changed=${changed_pos}"
fi
