#!/usr/bin/env bash
set -Eeuo pipefail
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
cd "$REPO_ROOT"
# JERBOA_SUPPRESS_BREADCRUMBS_V1
SUPPRESS_BREADCRUMBS="${JERBOA_SUPPRESS_BREADCRUMBS:-0}"

FORCE=0
if [ "${1:-}" = "--force" ]; then
  FORCE=1
  shift
fi

REPO="${HOME}/projects/market-health-cli"
[ -d "$REPO" ] || REPO="${REPO_ROOT}"
cd "$REPO" || { echo "ERROR: repo not found"; exit 1; }

# Gate: only run during regular NYSE session unless forced.
# (Simple weekday + 09:30–16:00 America/New_York. Keeps timer productive; avoids weekend churn.)
if [ "$FORCE" -ne 1 ]; then
  python3 - <<'PY' || exit 0
from datetime import datetime, time
from zoneinfo import ZoneInfo

now = datetime.now(ZoneInfo("America/New_York"))
# Mon-Fri only
if now.weekday() >= 5:
    raise SystemExit(1)

open_t  = time(9, 30)
close_t = time(16, 0)
t = now.time()

# Only refresh inside session
if not (open_t <= t <= close_t):
    raise SystemExit(1)

raise SystemExit(0)
PY
fi

# Run underlying refresh. Under systemd, suppress verbose stdout (keep logs clean).
if [ -n "${INVOCATION_ID:-}" ]; then
  scripts/cache/refresh_market_health_cache.sh "$@" >/dev/null
else
  scripts/cache/refresh_market_health_cache.sh "$@"
fi
rc=$?

# One breadcrumb only under systemd, only on success.
if [ "$rc" -eq 0 ] && [ -n "${INVOCATION_ID:-}" ]; then
  if [ "${SUPPRESS_BREADCRUMBS}" != "1" ]; then
  echo "OK: refreshed market cache (environment.v1.json)"
  fi
fi
exit "$rc"
