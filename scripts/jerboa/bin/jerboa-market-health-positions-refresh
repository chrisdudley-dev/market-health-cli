#!/usr/bin/env bash
set -Eeuo pipefail

REPO="${HOME}/projects/market-health-cli"
[ -d "$REPO" ] || REPO="/mnt/ssd/projects/market-health-cli"
cd "$REPO" || { echo "ERROR: repo not found"; exit 1; }

# Pass-through explicit CSV
if [ "${1:-}" = "--csv" ] && [ -n "${2:-}" ]; then
  exec scripts/cache/refresh_positions_cache.sh "$@"
fi

# Auto-pick best candidate CSV. If none found, ensure empty cache exists quietly and exit 0.
CSV="$(
python3 - <<'PY'
import os, glob, csv
from pathlib import Path

dirs = [
    os.path.expanduser("~/imports/thinkorswim"),
    os.path.expanduser("~/imports/tos"),
    os.path.expanduser("~/Downloads"),
]

wanted = {
    "symbol", "qty", "quantity", "net qty", "description",
    "mark", "market value", "average price", "avg price", "trade price",
}

def norm(x: str) -> str:
    return " ".join((x or "").strip().lower().split())

best = ("", -1, 0.0)  # (path, score, mtime)

for d in dirs:
    if not os.path.isdir(d):
        continue
    for p in glob.glob(os.path.join(d, "*.csv")):
        try:
            mt = Path(p).stat().st_mtime
            with open(p, "r", encoding="utf-8", errors="replace", newline="") as f:
                r = csv.reader(f)
                header = next(r, [])
            cols = {norm(c) for c in header if c is not None}
            score = sum(1 for w in wanted if w in cols)
            name = os.path.basename(p).lower()
            if any(k in name for k in ("pos", "position", "positions", "statement", "account")):
                score += 2
            if score > best[1] or (score == best[1] and mt > best[2]):
                best = (p, score, mt)
        except Exception:
            continue

# Require a minimum match to avoid grabbing random CSVs
if best[1] >= 2:
    print(best[0])
PY
)"

if [ -z "${CSV:-}" ]; then
  # Quietly ensure an empty cache exists so the widget always has something to read.
  python3 - <<'PY'
import json, os
from datetime import datetime, timezone

out = os.path.expanduser("~/.cache/jerboa/positions.v1.json")
payload = {
  "schema": "positions.v1",
  "asof": datetime.now(timezone.utc).isoformat(timespec="seconds"),
  "source": {"type": "none"},
  "positions": [],
  "summary": {"count": 0, "equities": 0, "options": 0, "symbols": []},
}
os.makedirs(os.path.dirname(out), exist_ok=True)
with open(out, "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=True)
    f.write("\n")
PY
  exit 0
fi

exec scripts/cache/refresh_positions_cache.sh --csv "$CSV"
