#!/usr/bin/env bash
set -Eeuo pipefail

# Resolve repo root from the real script path (works through ~/bin symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
cd "$REPO_ROOT"

DEFAULT_OUT="${HOME}/.cache/jerboa/positions.v1.json"
OUT="${DEFAULT_OUT}"
SCHWAB_JSON=""
CSV=""
POS_DIR="${HOME}/.config/jerboa/positions"

SEARCH_DIRS=()

usage() {
  cat <<USAGE
Usage:
  jerboa-market-health-positions-refresh [--out PATH]
    [--csv PATH] [--search-dir DIR ...]
    [--schwab-json PATH | --schwab-sample]

Env (optional):
  JERBOA_POSITIONS_SOURCE=schwab-sample
  JERBOA_POSITIONS_SOURCE=schwab-json:/path/to/accounts.json
  (unset) -> default ToS CSV behavior (auto-search + instructions)
USAGE
}

# env-based default (lets refresh-all use it without changing refresh-all yet)
case "${JERBOA_POSITIONS_SOURCE:-}" in
  schwab-sample)
    SCHWAB_JSON="${REPO_ROOT}/docs/examples/schwab_accounts.sample.json"
    ;;
  schwab-json:*)
    SCHWAB_JSON="${JERBOA_POSITIONS_SOURCE#schwab-json:}"
    ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    --out) OUT="${2:-}"; shift 2;;
    --csv) CSV="${2:-}"; shift 2;;
    --search-dir) SEARCH_DIRS+=("${2:-}"); shift 2;;
    --schwab-json) SCHWAB_JSON="${2:-}"; shift 2;;
    --schwab-sample) SCHWAB_JSON="${REPO_ROOT}/docs/examples/schwab_accounts.sample.json"; shift;;
    -h|--help) usage; exit 0;;
    *)
      echo "ERR: unknown arg: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

mkdir -p "$(dirname "$OUT")"
mkdir -p "$POS_DIR"
chmod 700 "$POS_DIR" 2>/dev/null || true

RAW_SCHWAB_JSON="${HOME}/.cache/jerboa/schwab_accounts.live.json"
TOKEN_FILE="${HOME}/.cache/jerboa/schwab.token.json"
SCHWAB_CONFIG_FILE="${HOME}/.config/jerboa/schwab_oauth.json"
RAW_MAX_AGE_MINUTES="${JERBOA_SCHWAB_RAW_MAX_AGE_MINUTES:-15}"

print_schwab_setup_hint() {
  if [ "${JERBOA_POSITIONS_HIDE_SCHWAB_HINT:-0}" = "1" ]; then
    return 0
  fi

  echo "Schwab live: not ready or not selected."
  echo "Schwab OAuth status:"
  hint_python="${JERBOA_MARKET_HEALTH_PYTHON:-}"
  if [ -z "$hint_python" ]; then
    if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
      hint_python="$REPO_ROOT/.venv/bin/python"
    else
      hint_python="python3"
    fi
  fi

  "$hint_python" "$REPO_ROOT/scripts/schwab_oauth_cli.py" --status 2>/dev/null | sed 's/^/  /' || true
  echo "To enable Schwab live positions, complete local config/token setup:"
  echo "  config: $SCHWAB_CONFIG_FILE"
  echo "  token:  $TOKEN_FILE"
}

if [ -z "$SCHWAB_JSON" ] && [ -z "$CSV" ] && [ "$OUT" = "$DEFAULT_OUT" ] && [ -f "$TOKEN_FILE" ]; then
  echo "Refreshing live Schwab data via token cache..."
  exec "${REPO_ROOT}/scripts/schwab_live_refresh.sh"
fi

if [ -z "$SCHWAB_JSON" ] && [ -z "$CSV" ] && [ -s "$RAW_SCHWAB_JSON" ]; then
  raw_mtime="$(stat -c %Y "$RAW_SCHWAB_JSON" 2>/dev/null || echo 0)"
  now_epoch="$(date +%s)"
  raw_age_seconds=$(( now_epoch - raw_mtime ))
  raw_age_minutes=$(( raw_age_seconds / 60 ))

  if [ "${RAW_MAX_AGE_MINUTES}" -gt 0 ] && [ "$raw_age_seconds" -gt $(( RAW_MAX_AGE_MINUTES * 60 )) ]; then
    echo "ERR: cached Schwab JSON is stale: $RAW_SCHWAB_JSON (${raw_age_minutes}m old)" >&2
    echo "Run scripts/schwab_live_refresh.sh, or pass --schwab-json/--csv explicitly." >&2
    echo "Set JERBOA_SCHWAB_RAW_MAX_AGE_MINUTES=0 to allow stale cached Schwab JSON." >&2
    exit 2
  fi

  echo "Using cached Schwab JSON: $RAW_SCHWAB_JSON (${raw_age_minutes}m old)"
  exec "${REPO_ROOT}/scripts/cache/refresh_positions_cache.sh" --schwab-json "$RAW_SCHWAB_JSON" --out "$OUT"
fi

# Schwab JSON path (offline for now)
if [ -n "$SCHWAB_JSON" ]; then
  if [ ! -f "$SCHWAB_JSON" ]; then
    echo "ERR: Schwab JSON not found: $SCHWAB_JSON" >&2
    exit 2
  fi
  echo "Using Schwab JSON: $SCHWAB_JSON"
  exec "${REPO_ROOT}/scripts/cache/refresh_positions_cache.sh" --schwab-json "$SCHWAB_JSON" --out "$OUT"
fi

# ToS CSV: explicit path wins
if [ -n "$CSV" ]; then
  echo "Using ToS CSV: $CSV"
  exec "${REPO_ROOT}/scripts/cache/refresh_positions_cache.sh" --csv "$CSV" --out "$OUT"
fi

# ToS CSV: auto-search
CANDIDATES=(
  "${POS_DIR}"
  "${HOME}/Downloads"
  "${HOME}/Desktop"
  "${HOME}/Documents"
)
for d in "${SEARCH_DIRS[@]}"; do
  CANDIDATES+=("$d")
done

best=""
best_ts="0"

for d in "${CANDIDATES[@]}"; do
  [ -d "$d" ] || continue
  # find recent-ish CSVs that smell like positions exports
  while IFS= read -r line; do
    t="${line%% *}"
    p="${line#* }"
    name="$(basename "$p" | tr '[:upper:]' '[:lower:]')"
    if echo "$name" | rg -q '(pos|position|positions|statement|account).*\.(csv)$'; then
      if awk "BEGIN{exit !($t > $best_ts)}"; then
        best_ts="$t"
        best="$p"
      fi
    fi
  done < <(find "$d" -maxdepth 2 -type f -iname '*.csv' -printf '%T@ %p\n' 2>/dev/null || true)
done

if [ -n "$best" ]; then
  echo "Using ToS CSV: $best"
  exec "${REPO_ROOT}/scripts/cache/refresh_positions_cache.sh" --csv "$best" --out "$OUT"
fi

print_schwab_setup_hint

if [ -s "$OUT" ]; then
  echo "Positions: keeping existing cache: $OUT"
  exit 0
fi

# No CSV found: leave placeholder behavior consistent and helpful
if [ ! -f "$OUT" ]; then
  cat > "$OUT" <<JSON
{
  "schema": "positions.v1",
  "generated_at": "$(date -Is)",
  "source": {"type":"none","note":"no positions source found"},
  "positions": [],
  "summary": {"count":0,"equities":0,"options":0}
}
JSON
fi

echo "Positions: none (no CSV found)."
echo "Put a Thinkorswim positions export CSV in one of these folders, then rerun:"
printf "  - %s\n" "${CANDIDATES[@]}"
echo
echo "Or run Schwab offline mode:"
echo "  jerboa-market-health-positions-refresh --schwab-sample"
exit 0
