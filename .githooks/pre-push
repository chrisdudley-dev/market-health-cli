#!/usr/bin/env bash
set -Eeuo pipefail

# Must be run inside a git repo.
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "[pre-push] Not a git repo; skipping."
  exit 0
fi

# Choose a comparison base for "what changed" detection.
# Priority:
#  1) $JERBOA_PREPUSH_BASE_REF (default origin/pi-grid) if it exists locally
#  2) upstream tracking branch (@{u}) if configured
#  3) HEAD~1..HEAD if HEAD~1 exists
#  4) fallback: unknown -> run ruff (safer than skipping)
BASE_REF="${JERBOA_PREPUSH_BASE_REF:-origin/pi-grid}"
RANGE=""

if git rev-parse -q --verify "${BASE_REF}" >/dev/null 2>&1; then
  RANGE="${BASE_REF}...HEAD"
elif git rev-parse -q --verify "@{u}" >/dev/null 2>&1; then
  RANGE="@{u}...HEAD"
elif git rev-parse -q --verify "HEAD~1" >/dev/null 2>&1; then
  RANGE="HEAD~1..HEAD"
else
  RANGE=""
fi

changed_py=""
if [ -n "${RANGE}" ]; then
  changed_py="$(git diff --name-only --diff-filter=ACM "${RANGE}" -- '*.py' || true)"
fi

if [ -z "${RANGE}" ]; then
  echo "[pre-push] No safe base ref found; running ruff (conservative)."
elif [ -z "${changed_py}" ]; then
  echo "[pre-push] No Python changes (${RANGE}); skipping ruff."
  exit 0
else
  echo "[pre-push] Python changes detected (${RANGE}); running ruff."
fi

# Prefer repo venv if present
if [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PY="python3"
else
  PY="python"
fi

if "${PY}" -m ruff --version >/dev/null 2>&1; then
  "${PY}" -m ruff format --check .
  "${PY}" -m ruff check .
elif command -v ruff >/dev/null 2>&1; then
  ruff format --check .
  ruff check .
else
  echo "ERROR: ruff not found. Install with: ${PY} -m pip install ruff" >&2
  exit 1
fi

# Optional:
# "${PY}" -m pytest -q
